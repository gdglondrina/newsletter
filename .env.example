# Transcription (required - OpenAI Whisper API)
OPENAI_API_KEY=sk-...

# AI Provider Configuration (choose one: 'claude', 'openai', 'gemini')
AI_PROVIDER=claude

# Provider API Keys (add the one you're using)
ANTHROPIC_API_KEY=sk-ant-...  # For Claude
# OPENAI_API_KEY already set above for Whisper (also used for GPT)
GOOGLE_API_KEY=...  # For Gemini

# === STT Configuration ===

# STT model: "whisper-1" (OpenAI API) or "faster-whisper" (local)
TRANSCRIPT_MODEL=faster-whisper

# Faster Whisper settings (only used when TRANSCRIPT_MODEL=faster-whisper)
FASTER_WHISPER_SIZE=medium
FASTER_WHISPER_DEVICE=cpu

# Optional
LOG_LEVEL=INFO
