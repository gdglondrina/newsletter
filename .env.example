# === API Keys ===

# OpenAI (used for Whisper STT and GPT models)
OPENAI_API_KEY=sk-...

# Anthropic (for Claude models)
ANTHROPIC_API_KEY=sk-ant-...

# Google (for Gemini models)
GOOGLE_API_KEY=...

# OpenRouter (for openrouter/ prefixed models)
OPENROUTER_API_KEY=sk-or-...

# === Model Configuration ===

# Default model for all stages (prefix determines provider)
# Examples: gpt-4o, claude-sonnet-4-5-20250929, gemini-1.5-pro, openrouter/qwen/qwen3-vl-30b-a3b-thinking
AI_MODEL=openrouter/qwen/qwen3-vl-30b-a3b-thinking

# Per-stage model overrides (optional, falls back to AI_MODEL)
SUMMARY_MODEL=openrouter/qwen/qwen3-vl-30b-a3b-thinking
# NEWSLETTER_MODEL=
# WHATSAPP_MODEL=

# STT model (default: whisper-1)
# TRANSCRIPT_MODEL=whisper-1

# === Optional ===

LOG_LEVEL=INFO
